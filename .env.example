# Legacy: current V3 pipeline does not use Anthropic for predictions.
ANTHROPIC_API_KEY=sk-ant-...

# Real trading via Polymarket official Python SDK (`py-clob-client`)
POLYMARKET_LIVE_TRADING=false
POLYMARKET_DRY_RUN=true
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Optional: provide existing L2 creds. If omitted, the bot derives them at runtime.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Live execution controls
POLYMARKET_ORDER_TYPE=FAK
POLYMARKET_MIN_LIVE_EDGE=0.0
POLYMARKET_MIN_SECONDS_TO_EXPIRY=45
POLYMARKET_MEDIUM_BET_USD=1
POLYMARKET_HIGH_BET_USD=1
